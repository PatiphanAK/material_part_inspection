# Copy to .env and fill in. Loaded with:  set -a; source .env; set +a
# NEVER commit real secrets — .env is git-ignored (.gitignore).

# lakeFS (S3-compatible gateway). Use a publicly reachable URL on Colab.
LAKEFS_ENDPOINT=http://localhost:8000
LAKEFS_ACCESS_KEY_ID=<from `lakefs setup` output>
LAKEFS_SECRET_ACCESS_KEY=<from `lakefs setup` output>
# Pin a commit SHA (not a branch name) for full reproducibility.
# Used by direct `python main.py ...` runs. For `dvc repro`, ALSO pin the same
# SHA in params.yaml (lakefs_commit:) — DVC tracks that file, not .env.
LAKEFS_COMMIT=<commit-sha>

# MLflow shared tracking server (postgres-backed, artifact proxy enabled).
MLFLOW_TRACKING_URI=http://localhost:5000
